    				<execution>
      					<goals>
        					<goal>compile</goal>
      					</goals>
    				</execution>
  				</executions>
			</plugin>-->

			<!-- Plugin para añadir el directorio de las clases generadas al build path, útil ya que permite al classpah hallar las clases generadas por el compilador de protobuf 
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>build-helper-maven-plugin</artifactId>
