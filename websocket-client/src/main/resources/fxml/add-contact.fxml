<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pola.controller.AddContactController"
      alignment="CENTER"
      spacing="20"
      styleClass="login-container">
    
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>
    
    <!-- Título -->
    <Label text="Agregar Contacto" styleClass="title">
        <font>
            <Font name="System Bold" size="28"/>
        </font>
    </Label>
    
    <!-- Formulario -->
    <VBox spacing="15" maxWidth="350">
        <Label text="Username del contacto:" styleClass="field-label"/>
        <TextField fx:id="usernameField" 
                   promptText="Ingrese el username"/>
        
        <!-- Botones -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="addButton" text="Agregar" styleClass="primary-button"/>
            <Button fx:id="cancelButton" text="Cancelar" styleClass="secondary-button"/>
        </HBox>
        
        <!-- Estado -->
        <Label fx:id="statusLabel" text="" styleClass="status-label"/>
    </VBox>
    
</VBox>