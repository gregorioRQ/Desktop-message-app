<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pola.controller.ChatController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f4f4f4; -fx-padding: 10; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
         <children>
            <Label fx:id="usernameLabel" style="-fx-font-weight: bold;" text="Usuario: " />
            <Label fx:id="statusLabel" text="Desconectado" textFill="RED" />
             <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="10.0">
                <children>
                   <Button fx:id="logoutButton" text="Cerrar Sesión" styleClass="logout-button" />
                   <Button fx:id="sseButton" text="Conectar SSE" styleClass="sse-button" />
                   <Button fx:id="connectButton" mnemonicParsing="false" text="Conectar" />
                   <Button fx:id="disconnectButton" disable="true" mnemonicParsing="false" text="Desconectar" />
                </children>
             </HBox>
         </children>
      </HBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.3" BorderPane.alignment="CENTER">
        <items>
            <TabPane tabClosingPolicy="UNAVAILABLE">
              <tabs>
                <Tab text="Contactos">
                     <content>
                        <VBox fx:id="contactsPanel" spacing="5.0">
                           <children>
                              <TextField fx:id="searchContactField" promptText="Buscar contacto..." />
                              <ListView fx:id="contactsListView" VBox.vgrow="ALWAYS" />
                              <Button fx:id="addContactButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Agregar Contacto" />
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                        </VBox>
                     </content>
                </Tab>
                <Tab>
                     <graphic>
                        <HBox alignment="CENTER" spacing="5.0">
                           <children>
                              <Label text="Notificaciones" />
                              <Circle fx:id="notificationBadge" fill="ORANGE" radius="5.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" visible="false" />
                           </children>
                        </HBox>
                     </graphic>
                     <content>
                        <VBox spacing="5.0">
                           <children>
                              <ListView fx:id="notificationsListView" VBox.vgrow="ALWAYS" />
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                        </VBox>
                     </content>
                </Tab>
              </tabs>
            </TabPane>
            <VBox spacing="5.0">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #e8e8e8; -fx-padding: 8; -fx-background-radius: 5;">
                     <children>
                        <Label fx:id="chatTitleLabel" maxWidth="1.7976931348623157E308" style="-fx-font-weight: bold; -fx-font-size: 14;" text="Selecciona un contacto" HBox.hgrow="ALWAYS" />
                        <Button fx:id="clearChatButton" mnemonicParsing="false" style="-fx-background-color: #ffdddd; -fx-text-fill: #cc0000; -fx-border-color: #cc0000; -fx-border-radius: 3; -fx-background-radius: 3;" text="Vaciar Chat" />
                     </children>
                  </HBox>
                  <StackPane VBox.vgrow="ALWAYS">
                     <children>
                        <ListView fx:id="messageListView" />
                        <Label fx:id="noContactsLabel" text="No tienes contactos. ¡Agrega uno!" visible="false" />
                     </children>
                  </StackPane>
                  <HBox spacing="5.0">
                     <children>
                        <TextArea fx:id="messageInput" disable="true" prefHeight="60.0" prefRowCount="2" promptText="Escribe un mensaje..." wrapText="true" HBox.hgrow="ALWAYS" />
                        <Button fx:id="sendButton" disable="true" maxHeight="1.7976931348623157E308" mnemonicParsing="false" prefWidth="80.0" style="-fx-base: #4CAF50;" text="Enviar" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
        </items>
      </SplitPane>
   </center>
</BorderPane>