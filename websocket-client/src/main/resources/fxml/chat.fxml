<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pola.controller.ChatController"
            styleClass="chat-container">
    
    <!-- Header -->
    <top>
        <VBox spacing="10" styleClass="header">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label fx:id="usernameLabel" text="Usuario: " styleClass="username-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel" text="Desconectado" styleClass="status-label"/>
            </HBox>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="connectButton" text="Conectar" styleClass="connect-button"/>
                <Button fx:id="disconnectButton" text="Desconectar" 
                        styleClass="disconnect-button" disable="true"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="addContactButton" text="+ Agregar Contacto" 
                        styleClass="primary-button"/>
            </HBox>
            
            <Separator/>
        </VBox>
    </top>
    
    <!-- Centro: Chat -->
    <center>
        <HBox spacing="0" HBox.hgrow="ALWAYS">
            <!-- Panel izquierdo: Lista de contactos -->
            <VBox spacing="10" prefWidth="250" styleClass="contacts-panel" 
                  VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                
                <Label text="Contactos:" styleClass="section-label"/>
                
                <TextField fx:id="searchContactField" 
                          promptText="Buscar contacto..."
                          style="-fx-background-radius: 5;"/>
                
                <ListView fx:id="contactsListView" styleClass="contacts-list" 
                         VBox.vgrow="ALWAYS"/>
                
                <Label fx:id="noContactsLabel" 
                       text="No hay contactos.&#10;Presiona '+ Agregar Contacto'"
                       styleClass="field-label"
                       wrapText="true"
                       alignment="CENTER"
                       visible="true"
                       style="-fx-text-alignment: center;"/>
            </VBox>
            
            <!-- Separador vertical -->
            <Separator orientation="VERTICAL"/>
            
            <!-- Panel derecho: Chat -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="10" right="15" bottom="10" left="15"/>
                </padding>
                
                <!-- Nombre del contacto seleccionado -->
                <Label fx:id="chatTitleLabel" 
                       text="Selecciona un contacto para chatear"
                       styleClass="section-label"
                       style="-fx-font-size: 16px;"/>
                
                <Separator/>
                
                <!-- Panel de mensajes -->
                <ListView fx:id="messageListView" VBox.vgrow="ALWAYS" 
                         styleClass="message-list"/>
                
                <!-- Campo de entrada -->
                <HBox spacing="10">
                    <TextArea fx:id="messageInput" promptText="Escribe tu mensaje aquí..."
                             wrapText="true" prefRowCount="3" HBox.hgrow="ALWAYS"
                             disable="true"/>
                    <Button fx:id="sendButton" text="Enviar" styleClass="send-button"
                           prefHeight="70" disable="true"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
    
    <!-- Panel derecho: Contactos (opcional) -->
    <right>
        <VBox fx:id="notificationsPanel" spacing="10" prefWidth="200" 
              styleClass="contacts-panel">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            
            <Label text="Notificaciones" styleClass="section-label"/>
            <ListView fx:id="notificationsListView" styleClass="contacts-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </right>
    
</BorderPane>