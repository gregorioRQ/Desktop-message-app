<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pola.controller.LoginController"
      alignment="CENTER"
      spacing="20"
      styleClass="login-container">
    
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>
    
    <!-- Título -->
    <Label text="WebSocket Client" styleClass="title">
        <font>
            <Font name="System Bold" size="28"/>
        </font>
    </Label>
    
    <!-- Formulario de login -->
    <VBox spacing="15" maxWidth="350">
        <Label text="Nombre de usuario:" styleClass="field-label"/>
        <TextField fx:id="usernameField" promptText="Ingrese su usuario"/>
        
        <Label text="Contraseña:" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" promptText="Ingrese su contraseña"/>
        
        <!-- Botones -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="loginButton" text="Iniciar Sesión" styleClass="primary-button"/>
            <Button fx:id="skipButton" text="Saltar" styleClass="secondary-button"/>
        </HBox>
        
        <!-- Estado -->
        <Label fx:id="statusLabel" text="" styleClass="status-label"/>

        <!-- Link a registro -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="¿No tienes cuenta?" styleClass="field-label"/>
            <Label fx:id="registerLink" text="Regístrate aquí" 
                   styleClass="link-label" 
                   onMouseClicked="#handleRegisterLink"/>
        </HBox>
    </VBox>
    
</VBox>